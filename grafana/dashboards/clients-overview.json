    {
      "id": 7,
      "title": "Top Talkers (by total traffic)",
      "type": "table",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "topk(10, unleashed_client_rx_bytes_total{site=~\"$site\"} + unleashed_client_tx_bytes_total{site=~\"$site\"})",
          "instant": true,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "unleashed_client_rx_pkts_total{site=~\"$site\"} + unleashed_client_tx_pkts_total{site=~\"$site\"}",
          "instant": true,
          "format": "table",
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
