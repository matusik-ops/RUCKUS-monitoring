            "matcher": {
              "id": "byName",
              "options": "RSSI (dBm)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dBm"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "value": -90,
                      "color": "red"
                    },
                    {
                      "value": -75,
                      "color": "yellow"
                    },
                    {
                      "value": -60,
                      "color": "green"
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Total Rx"
            },
            "properties": [
              {
                "id": "unit",
                "value": "decbytes"
              }
            ]
          },
