              "__name__": true,
              "job": true,
              "instance": true,
              "Value #info": true,
              "ap_name": true,
              "auth_method": true,
              "client_mac": true,
              "dvctype": true,
              "encryption": true,
              "ip": true,
              "model_os": true,
              "radio_band": true,
              "site": true,
              "ssid": true,
              "vlan": true
            },
            "renameByName": {
              "hostname": "Hostname",
              "apz_device": "Device",
              "Value #rssi": "RSSI (dBm)",
              "Value #snr": "SNR",
              "Value #noise": "Noise",
              "Value #chan": "Channel",
              "Value #linkspeed": "Link Mbps",
              "Value #rxmbps": "Rx Mbps",
              "Value #txmbps": "Tx Mbps",
              "Value #rxbytes": "Total Rx",
              "Value #txbytes": "Total Tx",
              "Value #rxpps": "Rx pkt/s",
              "Value #txpps": "Tx pkt/s",
              "Value #txpkts": "Total Tx pkts",
              "Value #rxpkts": "Total Rx pkts",
              "Value #retries": "Retries",
              "Value #duration": "Connected For"
            }
          }
        },
        {
