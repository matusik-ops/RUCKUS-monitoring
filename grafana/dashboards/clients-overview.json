{
  "uid": "ruckus-clients-overview",
  "title": "Ruckus Clients Overview",
  "tags": [
    "ruckus",
    "clients",
    "inventory"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "site",
        "label": "Site",
        "type": "query",
        "query": "label_values(unleashed_ap_num_sta, site)",
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "multi": true,
        "sort": 1
      },
      {
        "name": "ap_name",
        "type": "query",
        "query": "label_values(unleashed_client_info{site=~\"$site\"}, ap_name)",
        "datasource": "Prometheus",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "ssid",
        "type": "query",
        "query": "label_values(unleashed_client_info{site=~\"$site\", ap_name=~\"$ap_name\"}, ssid)",
        "datasource": "Prometheus",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "radio_band",
        "type": "custom",
        "query": "2.4g,5g",
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          },
          {
            "text": "2.4 GHz",
            "value": "2.4g"
          },
          {
            "text": "5 GHz",
            "value": "5g"
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Clients",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(unleashed_client_info{site=~\"$site\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "blue"
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Clients per Band",
      "type": "piechart",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "count by (radio_band) (unleashed_client_info{site=~\"$site\"})",
          "legendFormat": "{{ radio_band }}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Clients per SSID",
      "type": "piechart",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "count by (ssid) (unleashed_client_info{site=~\"$site\"})",
          "legendFormat": "{{ ssid }}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Clients per AP",
      "type": "piechart",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "count by (ap_name) (unleashed_client_info{site=~\"$site\"})",
          "legendFormat": "{{ ap_name }}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Client Inventory",
      "type": "table",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "cellHeight": "sm"
      },
      "targets": [
        {
          "expr": "label_replace(unleashed_client_info{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}, \"apz_device\", \"-\", \"apz_device\", \"^$\")",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "Value": true
            },
            "renameByName": {
              "hostname": "Hostname",
              "apz_device": "Device",
              "client_mac": "MAC",
              "dvctype": "Type",
              "model_os": "OS",
              "ip": "IP",
              "vlan": "VLAN",
              "ap_name": "AP",
              "ssid": "SSID",
              "radio_band": "Band",
              "auth_method": "Auth",
              "encryption": "Encryption"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Hostname",
                "desc": false
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Device"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "Client Live Stats",
      "type": "table",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        },
        "cellHeight": "sm"
      },
      "targets": [
        {
          "expr": "unleashed_client_info{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "info"
        },
        {
          "expr": "unleashed_client_rssi_dbm{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "rssi"
        },
        {
          "expr": "unleashed_client_snr_db{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "snr"
        },
        {
          "expr": "unleashed_client_noise_floor_dbm{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "noise"
        },
        {
          "expr": "unleashed_client_channel{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "chan"
        },
        {
          "expr": "unleashed_client_tx_rate_kbps{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"} / 1000",
          "instant": true,
          "format": "table",
          "refId": "linkspeed"
        },
        {
          "expr": "clamp_max(rate(unleashed_client_rx_bytes_total{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}[1m]) * 8 / 1000000, 500)",
          "instant": true,
          "format": "table",
          "refId": "rxmbps"
        },
        {
          "expr": "clamp_max(rate(unleashed_client_tx_bytes_total{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}[1m]) * 8 / 1000000, 500)",
          "instant": true,
          "format": "table",
          "refId": "txmbps"
        },
        {
          "expr": "unleashed_client_rx_bytes_total{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "rxbytes"
        },
        {
          "expr": "unleashed_client_tx_bytes_total{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "txbytes"
        },
        {
          "expr": "rate(unleashed_client_rx_pkts_total{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}[1m])",
          "instant": true,
          "format": "table",
          "refId": "rxpps"
        },
        {
          "expr": "rate(unleashed_client_tx_pkts_total{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}[1m])",
          "instant": true,
          "format": "table",
          "refId": "txpps"
        },
        {
          "expr": "unleashed_client_tx_pkts_total{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "txpkts"
        },
        {
          "expr": "unleashed_client_rx_pkts_total{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "rxpkts"
        },
        {
          "expr": "unleashed_client_retries_total{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "retries"
        },
        {
          "expr": "time() - unleashed_client_assoc_time_seconds{site=~\"$site\", ap_name=~\"$ap_name\", ssid=~\"$ssid\", radio_band=~\"$radio_band\"}",
          "instant": true,
          "format": "table",
          "refId": "duration"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "hostname",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
