{
  "uid": "ruckus-radio-health",
  "title": "Ruckus R720 - Radio Health",
  "tags": [
    "ruckus",
    "r720",
    "radio"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "query": "label_values(up{job=\"snmp\"}, instance)",
        "datasource": "Prometheus",
        "refresh": 2,
        "current": {}
      },
      {
        "name": "radioIndex",
        "type": "custom",
        "query": "1,2",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "allValue": ".*",
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          },
          {
            "text": "2.4GHz (1)",
            "value": "1"
          },
          {
            "text": "5GHz (2)",
            "value": "2"
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Channel Utilization",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "ruckusRadioStatsResourceUtil{instance=\"$instance\", radioIndex=~\"$radioIndex\"}",
          "legendFormat": "Radio {{ radioIndex }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 50,
                "color": "yellow"
              },
              {
                "value": 80,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Busy Airtime Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(ruckusRadioStatsBusyAirtime{instance=\"$instance\", radioIndex=~\"$radioIndex\"}[5m])",
          "legendFormat": "Radio {{ radioIndex }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Auth Failure Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "ruckusRadioStatsAuthFailRate{instance=\"$instance\", radioIndex=~\"$radioIndex\"}",
          "legendFormat": "Radio {{ radioIndex }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 5,
                "color": "yellow"
              },
              {
                "value": 10,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Association Failure Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "ruckusRadioStatsAssocFailRate{instance=\"$instance\", radioIndex=~\"$radioIndex\"}",
          "legendFormat": "Radio {{ radioIndex }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 5,
                "color": "yellow"
              },
              {
                "value": 10,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Tx Retries / Failures / Drops",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(ruckusUnleashedSystemStatsWLANTotalTxRetry{instance=\"$instance\"}[5m])",
          "legendFormat": "Tx Retries/s",
          "refId": "A"
        },
        {
          "expr": "rate(ruckusUnleashedSystemStatsWLANTotalTxFail{instance=\"$instance\"}[5m])",
          "legendFormat": "Tx Failures/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Rx Errors",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(ruckusRadioStatsRxErrors{instance=\"$instance\", radioIndex=~\"$radioIndex\"}[5m])",
          "legendFormat": "Radio {{ radioIndex }} Rx Errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "CPU Utilization",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "ruckusUnleashedSystemStatsCPUUtil{instance=\"$instance\"}",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Memory Utilization",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "ruckusUnleashedSystemStatsMemoryUtil{instance=\"$instance\"}",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "red"
              }
            ]
          }
        }
      }
    }
  ]
}