{
  "uid": "ruckus-radio-health",
  "title": "Ruckus R720 - Radio Health",
  "tags": ["ruckus", "r720", "radio"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "ap_name",
        "type": "query",
        "query": "label_values(unleashed_radio_airtime_total, ap_name)",
        "datasource": "Prometheus",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "radio_band",
        "type": "custom",
        "query": "2.4g,5g",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "2.4 GHz", "value": "2.4g" },
          { "text": "5 GHz", "value": "5g" }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Airtime Utilization (busy/total %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "unleashed_radio_airtime_busy{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"} / unleashed_radio_airtime_total{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"} * 100",
          "legendFormat": "{{ ap_name }} {{ radio_band }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 30, "color": "yellow" }, { "value": 50, "color": "red" }] },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      }
    },
    {
      "id": 2,
      "title": "Airtime Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "unleashed_radio_airtime_busy{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }} busy",
          "refId": "A"
        },
        {
          "expr": "unleashed_radio_airtime_rx{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }} rx",
          "refId": "B"
        },
        {
          "expr": "unleashed_radio_airtime_tx{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }} tx",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Clients per Radio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "unleashed_radio_num_sta{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg RSSI per Radio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "unleashed_radio_avg_rssi{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Auth Failures per Radio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "unleashed_radio_auth_fail{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 100, "color": "yellow" }, { "value": 500, "color": "red" }] }
        }
      }
    },
    {
      "id": 6,
      "title": "Assoc Failures per Radio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "unleashed_radio_assoc_fail{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Tx Retries per Radio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "unleashed_radio_retries_total{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Tx Failures per Radio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "unleashed_radio_tx_fail_total{ap_name=~\"$ap_name\", radio_band=~\"$radio_band\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "CPU Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "ruckusUnleashedSystemStatsCPUUtil",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "max": 100,
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 90, "color": "red" }] }
        }
      }
    },
    {
      "id": 10,
      "title": "Memory Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "ruckusUnleashedSystemStatsMemoryUtil",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "max": 100,
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 90, "color": "red" }] }
        }
      }
    }
  ]
}
