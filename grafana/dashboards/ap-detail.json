{
  "uid": "ruckus-ap-detail",
  "title": "Ruckus R720 - AP Detail",
  "tags": ["ruckus", "r720", "detail"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "ap_name",
        "type": "query",
        "query": "label_values(unleashed_radio_num_sta, ap_name)",
        "datasource": "Prometheus",
        "refresh": 2,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "System Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sysUpTime / 100",
          "legendFormat": "Uptime",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 2,
      "title": "CPU",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "ruckusUnleashedSystemStatsCPUUtil",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "max": 100,
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 90, "color": "red" }] }
        }
      }
    },
    {
      "id": 3,
      "title": "Memory",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "ruckusUnleashedSystemStatsMemoryUtil",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "max": 100,
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 90, "color": "red" }] }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Clients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "sum(unleashed_radio_num_sta{ap_name=\"$ap_name\"})",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Clients per Radio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "unleashed_radio_num_sta{ap_name=\"$ap_name\", radio_band=\"2.4g\"}",
          "legendFormat": "2.4GHz (ch {{ channel }})",
          "refId": "A"
        },
        {
          "expr": "unleashed_radio_num_sta{ap_name=\"$ap_name\", radio_band=\"5g\"}",
          "legendFormat": "5GHz (ch {{ channel }})",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Airtime Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "increase(unleashed_radio_airtime_busy{ap_name=\"$ap_name\", radio_band=\"2.4g\"}[5m]) / clamp_min(increase(unleashed_radio_airtime_total{ap_name=\"$ap_name\", radio_band=\"2.4g\"}[5m]), 1) * 100",
          "legendFormat": "2.4GHz busy %",
          "refId": "A"
        },
        {
          "expr": "increase(unleashed_radio_airtime_busy{ap_name=\"$ap_name\", radio_band=\"5g\"}[5m]) / clamp_min(increase(unleashed_radio_airtime_total{ap_name=\"$ap_name\", radio_band=\"5g\"}[5m]), 1) * 100",
          "legendFormat": "5GHz busy %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 30, "color": "yellow" }, { "value": 50, "color": "red" }] },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        }
      }
    },
    {
      "id": 7,
      "title": "Radio Tx Bytes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "unleashed_radio_tx_bytes_total{ap_name=\"$ap_name\", radio_band=\"2.4g\"}",
          "legendFormat": "2.4GHz Tx",
          "refId": "A"
        },
        {
          "expr": "unleashed_radio_tx_bytes_total{ap_name=\"$ap_name\", radio_band=\"5g\"}",
          "legendFormat": "5GHz Tx",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "id": 8,
      "title": "Radio Rx Bytes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "unleashed_radio_rx_bytes_total{ap_name=\"$ap_name\", radio_band=\"2.4g\"}",
          "legendFormat": "2.4GHz Rx",
          "refId": "A"
        },
        {
          "expr": "unleashed_radio_rx_bytes_total{ap_name=\"$ap_name\", radio_band=\"5g\"}",
          "legendFormat": "5GHz Rx",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    },
    {
      "id": 9,
      "title": "Tx Retries per Radio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "unleashed_radio_retries_total{ap_name=\"$ap_name\", radio_band=\"2.4g\"}",
          "legendFormat": "2.4GHz retries",
          "refId": "A"
        },
        {
          "expr": "unleashed_radio_retries_total{ap_name=\"$ap_name\", radio_band=\"5g\"}",
          "legendFormat": "5GHz retries",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "title": "Auth / Assoc Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "unleashed_radio_auth_fail{ap_name=\"$ap_name\", radio_band=\"2.4g\"}",
          "legendFormat": "2.4GHz auth fail",
          "refId": "A"
        },
        {
          "expr": "unleashed_radio_auth_fail{ap_name=\"$ap_name\", radio_band=\"5g\"}",
          "legendFormat": "5GHz auth fail",
          "refId": "B"
        },
        {
          "expr": "unleashed_radio_assoc_fail{ap_name=\"$ap_name\", radio_band=\"2.4g\"}",
          "legendFormat": "2.4GHz assoc fail",
          "refId": "C"
        },
        {
          "expr": "unleashed_radio_assoc_fail{ap_name=\"$ap_name\", radio_band=\"5g\"}",
          "legendFormat": "5GHz assoc fail",
          "refId": "D"
        }
      ]
    },
    {
      "id": 11,
      "title": "Ethernet Interface Status",
      "type": "table",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "ifOperStatus",
          "legendFormat": "{{ ifDescr }}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "2": { "text": "DOWN", "color": "red" } } }
          ]
        }
      }
    }
  ]
}
