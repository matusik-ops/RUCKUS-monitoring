{
  "uid": "ruckus-ap-detail",
  "title": "Ruckus R720 - AP Detail",
  "tags": [
    "ruckus",
    "r720",
    "detail"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "query": "label_values(up{job=\"snmp\"}, instance)",
        "datasource": "Prometheus",
        "refresh": 2,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "System Uptime",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sysUpTime{instance=\"$instance\"} / 100",
          "legendFormat": "Uptime",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 2,
      "title": "CPU",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "ruckusUnleashedSystemStatsCPUUtil{instance=\"$instance\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Memory",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "ruckusUnleashedSystemStatsMemoryUtil{instance=\"$instance\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Clients",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "ruckusUnleashedSystemStatsAllNumSta{instance=\"$instance\"}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Clients per Radio",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "ruckusRadioStatsNumAuthSta{instance=\"$instance\", radioIndex=\"1\"}",
          "legendFormat": "2.4GHz Clients",
          "refId": "A"
        },
        {
          "expr": "ruckusRadioStatsNumAuthSta{instance=\"$instance\", radioIndex=\"2\"}",
          "legendFormat": "5GHz Clients",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Channel Utilization per Radio",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "ruckusRadioStatsResourceUtil{instance=\"$instance\", radioIndex=\"1\"}",
          "legendFormat": "2.4GHz Util %",
          "refId": "A"
        },
        {
          "expr": "ruckusRadioStatsResourceUtil{instance=\"$instance\", radioIndex=\"2\"}",
          "legendFormat": "5GHz Util %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100
        }
      }
    },
    {
      "id": 7,
      "title": "Radio Traffic (Rx)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(ruckusRadioStatsRxBytes{instance=\"$instance\", radioIndex=\"1\"}[5m]) * 8",
          "legendFormat": "2.4GHz Rx bps",
          "refId": "A"
        },
        {
          "expr": "rate(ruckusRadioStatsRxBytes{instance=\"$instance\", radioIndex=\"2\"}[5m]) * 8",
          "legendFormat": "5GHz Rx bps",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      }
    },
    {
      "id": 8,
      "title": "Radio Traffic (Tx)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(ruckusRadioStatsTxBytes{instance=\"$instance\", radioIndex=\"1\"}[5m]) * 8",
          "legendFormat": "2.4GHz Tx bps",
          "refId": "A"
        },
        {
          "expr": "rate(ruckusRadioStatsTxBytes{instance=\"$instance\", radioIndex=\"2\"}[5m]) * 8",
          "legendFormat": "5GHz Tx bps",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      }
    },
    {
      "id": 9,
      "title": "Ethernet Interface Status",
      "type": "table",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "ifOperStatus{instance=\"$instance\"}",
          "legendFormat": "{{ ifDescr }}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "2": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ]
        }
      }
    }
  ]
}