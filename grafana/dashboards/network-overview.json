{
  "uid": "ruckus-network-overview",
  "title": "Ruckus Network Overview",
  "tags": [
    "ruckus",
    "overview",
    "noc"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 100,
      "title": "",
      "type": "text",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "# Network Status"
      }
    },
    {
      "id": 501,
      "title": "Active Issues",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 2
      },
      "targets": [
        {
          "expr": "(count(unleashed_client_rssi_dbm < -70) or vector(0)) + (count(sum by (ap_name) (increase(unleashed_radio_auth_fail[5m])) / clamp_min(sum by (ap_name) (increase(unleashed_radio_auth_fail[5m]) + increase(unleashed_radio_auth_success[5m])), 1) > 0.2) or vector(0)) + (count(increase(unleashed_radio_airtime_busy[5m]) / clamp_min(increase(unleashed_radio_airtime_total[5m]), 1) > 0.4) or vector(0))",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "textMode": "value",
        "graphMode": "none",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "ALL OK",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 502,
      "title": "Total Throughput",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 2
      },
      "targets": [
        {
          "expr": "sum(rate(ruckusUnleashedSystemStatsWLANTotalTxBytes[5m]) + rate(ruckusUnleashedSystemStatsWLANTotalRxBytes[5m])) * 8",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "textMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "blue"
              }
            ]
          }
        }
      }
    },
    {
      "id": 503,
      "title": "APs with Clients",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 2
      },
      "targets": [
        {
          "expr": "count(sum by (ap_name) (unleashed_radio_num_sta) > 0)",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "ruckusUnleashedSystemStatsNumAP",
          "instant": true,
          "refId": "B"
        }
      ],
      "options": {
        "textMode": "value_and_name",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "blue"
              }
            ]
          }
        }
      }
    },
