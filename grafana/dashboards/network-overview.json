    {
      "id": 20,
      "title": "Weak Signal (RSSI < -70 dBm)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "unleashed_client_rssi_dbm and (unleashed_client_rssi_dbm < bool -70 == 1)",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "All clients OK"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "RSSI (dBm)"
              },
              {
                "id": "thresholds",
                "value": {
                  "steps": [
                    {
                      "value": -90,
                      "color": "red"
                    },
                    {
                      "value": -75,
                      "color": "yellow"
                    },
                    {
                      "value": -60,
                      "color": "green"
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "client_mac": false
            },
            "renameByName": {
              "hostname": "Hostname",
              "client_mac": "MAC",
              "ap_name": "AP",
              "ssid": "SSID",
              "radio_band": "Band"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "RSSI (dBm)",
                "desc": false
              }
            ]
          }
        }
      ]
    },
    {
