      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 5,
                "color": "yellow"
              },
              {
                "value": 7,
                "color": "green"
              }
