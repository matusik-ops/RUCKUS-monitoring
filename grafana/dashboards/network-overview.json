    {
      "id": 14,
      "title": "Throughput per AP",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "sum by (ap_name) (rate(unleashed_radio_tx_bytes_total{site=~\"$site\"}[5m]) + rate(unleashed_radio_rx_bytes_total{site=~\"$site\"}[5m])) * 8 > 0",
          "legendFormat": "{{ ap_name }}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 5000000,
                "color": "yellow"
              },
              {
                "value": 50000000,
                "color": "red"
              }
            ]
          },
          "links": [
            {
              "title": "AP Detail",
              "url": "/d/ruckus-ap-detail?var-ap_name=${__field.labels.ap_name}"
            }
          ]
        }
      }
    },
    {
      "id": 10,
      "title": "Clients per AP",
