    {
      "id": 251,
      "title": "Radio Off/On Events (DFS)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "targets": [
        {
          "expr": "unleashed_ap_radio_off_total{site=~\"$site\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }} OFF",
          "refId": "A"
        },
        {
          "expr": "unleashed_ap_radio_on_total{site=~\"$site\"}",
          "legendFormat": "{{ ap_name }} {{ radio_band }} ON",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "points",
            "pointSize": 8
          }
        }
      }
    },
    {
      "id": 252,
      "title": "DFS / Radio Event History",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "expr": "unleashed_alarm_radio_event{site=~\"$site\"}",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "site": true,
              "event_id": true
            },
            "renameByName": {
              "ap_name": "AP",
              "radio_band": "Band",
              "event_type": "Event",
              "Value": "Timestamp"
            },
            "indexByName": {
              "ap_name": 0,
              "radio_band": 1,
              "event_type": 2,
              "Value": 3
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "field": "Timestamp",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Timestamp"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeFromNow"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Event"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "off": { "text": "Radio OFF", "color": "red" },
                      "on": { "text": "Radio ON", "color": "green" }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          }
        ]
      }
    },
    {
