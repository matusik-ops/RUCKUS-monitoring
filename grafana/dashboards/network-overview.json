{
  "uid": "ruckus-network-overview",
  "title": "Ruckus Network Overview",
  "tags": [
    "ruckus",
    "overview",
    "noc"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "site",
        "label": "Site",
        "type": "query",
        "query": "label_values(unleashed_ap_num_sta, site)",
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "multi": true,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "",
      "type": "text",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "# Network Status"
      }
    },
    {
      "id": 501,
      "title": "Active Issues",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 2
      },
      "targets": [
        {
          "expr": "(count(unleashed_client_rssi_dbm{site=~\"$site\"} < -70) or vector(0)) + (count(sum by (ap_name) (unleashed_radio_auth_fail{site=~\"$site\"}) / clamp_min(sum by (ap_name) (unleashed_radio_auth_fail{site=~\"$site\"} + unleashed_radio_auth_success{site=~\"$site\"}), 1) > 0.05) or vector(0)) + (count(unleashed_radio_airtime_busy{site=~\"$site\"} / clamp_min(unleashed_radio_airtime_total{site=~\"$site\"}, 1) > 0.4) or vector(0))",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "textMode": "value",
        "graphMode": "none",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "ALL OK",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 502,
      "title": "Total Throughput",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 2
      },
      "targets": [
        {
          "expr": "sum(rate(ruckusUnleashedSystemStatsWLANTotalTxBytes{site=~\"$site\"}[5m]) + rate(ruckusUnleashedSystemStatsWLANTotalRxBytes{site=~\"$site\"}[5m])) * 8",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "textMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "blue"
              }
            ]
          }
        }
      }
    },
    {
      "id": 503,
      "title": "APs with Clients",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 2
      },
      "targets": [
        {
          "expr": "count(sum by (ap_name) (unleashed_radio_num_sta{site=~\"$site\"}) > 0)",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "ruckusUnleashedSystemStatsNumAP{site=~\"$site\"}",
          "instant": true,
          "refId": "B"
        }
      ],
      "options": {
        "textMode": "value_and_name",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "blue"
              }
            ]
          }
        }
      }
    },
    {
      "id": 504,
      "title": "Weak-Signal Clients",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 2
      },
      "targets": [
        {
          "expr": "count(unleashed_client_rssi_dbm{site=~\"$site\"} < -70) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "textMode": "value",
        "graphMode": "none",
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "yellow"
              },
              {
                "value": 5,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 1,
      "title": "APs Online",
      "type": "stat",
