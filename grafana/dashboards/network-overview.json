    {
      "id": 20,
      "title": "Weak Signal (RSSI < -70 dBm)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 48
      },
      "targets": [
        {
          "expr": "unleashed_client_rssi_dbm{site=~\"$site\"} and (unleashed_client_rssi_dbm{site=~\"$site\"} < bool -70 == 1)",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "All clients OK"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "RSSI (dBm)"
              },
