# Alert Thresholds
ALERT_AP_DOWN_MINUTES=5
ALERT_CHANNEL_UTIL_PERCENT=80
ALERT_CLIENT_COUNT_MAX=50
ALERT_AUTH_FAIL_RATE=10
ALERT_TX_RETRY_RATE=1000
ALERT_CPU_PERCENT=90
ALERT_CLIENT_RSSI_MIN=-75

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# WAN Monitoring
GATEWAY_IP=10.91.1.254
